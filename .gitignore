# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# Data files — never commit raw data
data/raw/
data/processed/
*.csv
*.db

# Allow deploy data — small committed subset for production
!data/deploy/
!data/deploy/*.parquet

# Model files — too large for git
models/*.pkl
models/*.joblib

# Allow small encoder files — safe to commit
!models/label_encoder.pkl
!models/pitcher_encoder.pkl

# pybaseball cache
.pybaseball/

# Environment
.env
*.env

# Anaconda / virtual envs
.conda/
env/
venv/

# OS
.DS_Store
Thumbs.db

# Docker
*.dockerignore

# Pytest
.pytest_cache/

# Coverage reports (if coverage is added later)
htmlcov/
.coverage

# IDE
.vscode/
.idea/
*.swp
